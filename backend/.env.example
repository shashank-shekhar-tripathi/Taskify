# Copy this file to .env and fill in your values

# Generate a strong secret key: https://djecrety.ir/
SECRET_KEY=your-very-strong-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated allowed hosts
ALLOWED_HOSTS=your-railway-app.up.railway.app,localhost

# PostgreSQL URL from Railway (auto-provided)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Your Vercel frontend URL (add after deploying frontend)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
